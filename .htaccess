Options -Indexes
DirectoryIndex index.php

# Blok akses langsung ke folder includes
<FilesMatch "^(config|navbar|footer)\.php$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
